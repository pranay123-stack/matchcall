# MatchCall backend environment (copy to app/.env.local).
# Every value has a safe devnet default in code; you only MUST set the ones
# marked REQUIRED before creating/settling markets or running the faucet.

# ---------------------------------------------------------------------------
# Solana (devnet)
# ---------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.devnet.solana.com
PREDICTION_ESCROW_PROGRAM_ID=DuB3yJQMPWCESJoEzShBWt1Jc3Q6j6DXLyi1XpAB6EQ2
MUSDC_MINT=EgkrEEpXKn61tdWDTJj9bDd68oW4ifiUC4M5uqiAhv9j

# Backend signer (creator/cranker/faucet fee payer). REQUIRED for POST /api/markets,
# settlement, and initialize_config. A JSON byte array, e.g. [12,34,...].
# Tip: MARKET_AUTHORITY_SECRET=$(cat .keys/deployer.json)
MARKET_AUTHORITY_SECRET=
# Alternative to the inline secret: a path to a keypair JSON file.
MARKET_AUTHORITY_KEYPAIR_PATH=.keys/deployer.json

# Ops keypairs used by scripts (repo-root relative paths).
DEPLOYER_KEYPAIR_PATH=.keys/deployer.json
MUSDC_MINT_KEYPAIR_PATH=.keys/musdc-mint.json

# ---------------------------------------------------------------------------
# TxLINE (devnet). Populate JWT + token by running: npm run txline:activate
# ---------------------------------------------------------------------------
TXLINE_BASE_URL=https://txline-dev.txodds.com/api/
TXLINE_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_URL=https://txline-dev.txodds.com/auth/guest/start
TXLINE_AUTH_JWT=
TXLINE_API_TOKEN=
# Optional: restrict the fixtures snapshot to a single competition id.
TXLINE_COMPETITION_ID=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
DATABASE_PATH=./matchcall.db

# ---------------------------------------------------------------------------
# Public (exposed to the frontend bundle — safe, non-secret)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=DuB3yJQMPWCESJoEzShBWt1Jc3Q6j6DXLyi1XpAB6EQ2
NEXT_PUBLIC_MUSDC_MINT=EgkrEEpXKn61tdWDTJj9bDd68oW4ifiUC4M5uqiAhv9j
